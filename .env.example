# Copy to .env.local and fill in what you need. All variables are optional.

# ─── Instagram authentication for yt-dlp ────────────────────────────────────
# Instagram rate-limits or blocks anonymous access, especially from
# datacenter/server IPs. Supplying logged-in cookies fixes "login required"
# and rate-limit download failures.

# Path to a Netscape-format cookies.txt exported while logged in to
# instagram.com (e.g. with the "Get cookies.txt LOCALLY" browser extension).
# Takes precedence over INSTAGRAM_COOKIES_FROM_BROWSER. Recommended for
# production servers.
#INSTAGRAM_COOKIES_FILE=C:\secrets\instagram-cookies.txt

# Or extract cookies from a browser installed on this machine (dev only).
# Same values as yt-dlp --cookies-from-browser: chrome, edge, firefox,
# brave, opera — optionally with a profile, e.g. "chrome:Profile 1".
#INSTAGRAM_COOKIES_FROM_BROWSER=chrome
